# Syncore Email Verifier — deployment env file (TEMPLATE).
#
# Copy to /etc/syncore/email-verifier.env, populate from your secret vault, and
# lock it down: `chown syncore:syncore` + `chmod 600`. The systemd unit loads it
# via EnvironmentFile=; for PM2, source it before `pm2 start`. The service reads
# these from the process environment (no dotenv, no .env auto-load).

# --- Bind & auth (read §"Deployment targets" in deploy/README.md) ---
# Loopback co-located with the CRM. For a private-subnet bind, set the private
# address here AND set the auth token below (startup FAILS on a non-loopback
# bind with no token).
SYNCORE_VERIFIER_BIND_ADDR=127.0.0.1:8080
# Machine-to-machine bearer token. REQUIRED for any non-loopback bind. Leave
# unset only for a pure loopback deployment.
# SYNCORE_VERIFIER_AUTH_TOKEN=replace-with-a-long-random-secret

# --- SMTP (see the port-25 reality in deploy/README.md) ---
SYNCORE_VERIFIER_SMTP_ENABLED=true
SYNCORE_VERIFIER_FROM_EMAIL=hello@syncoretech.com
SYNCORE_VERIFIER_HELLO_NAME=syncoretech.com
SYNCORE_VERIFIER_CONNECT_TIMEOUT=10s
SYNCORE_VERIFIER_OPERATION_TIMEOUT=10s

# --- Result cache (off unless a TTL is set) ---
# SYNCORE_VERIFIER_CACHE_TTL=30m
# SYNCORE_VERIFIER_CACHE_TTL_UNKNOWN=1m
# SYNCORE_VERIFIER_CACHE_MAX_ENTRIES=10000

# --- Batch endpoint bounds (the CRM must chunk to BATCH_MAX_ITEMS) ---
SYNCORE_VERIFIER_BATCH_MAX_ITEMS=100
SYNCORE_VERIFIER_BATCH_CONCURRENCY=10
SYNCORE_VERIFIER_BATCH_MAX_BODY_BYTES=65536

# --- Optional signals ---
SYNCORE_VERIFIER_DOMAIN_SUGGEST=true
# SYNCORE_VERIFIER_DOMAIN_HEALTH=false
SYNCORE_VERIFIER_MAX_BODY_BYTES=4096
SYNCORE_VERIFIER_DISPOSABLE_AUTOUPDATE=false
