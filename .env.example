# Syncore Email Verifier — environment configuration (DOCUMENTATION ONLY).
#
# The service reads process environment variables directly. It does NOT load
# this file, and there is no dotenv dependency. Copy the values you need into
# your shell or orchestrator environment (e.g. `export NAME=value`, or your
# container/systemd unit configuration).

# Address the HTTP server binds to (host:port). Default binds to loopback only.
SYNCORE_VERIFIER_BIND_ADDR=127.0.0.1:8080

# Enable mailbox-level SMTP verification (true/false).
SYNCORE_VERIFIER_SMTP_ENABLED=true

# MAIL FROM address used during SMTP checks. Validated only when SMTP is enabled.
SYNCORE_VERIFIER_FROM_EMAIL=hello@syncoretech.com

# EHLO/HELO name used during SMTP checks. Validated only when SMTP is enabled;
# must be non-empty with no whitespace or control characters.
SYNCORE_VERIFIER_HELLO_NAME=syncoretech.com

# TCP connect timeout for SMTP dialing (Go duration, must be > 0).
SYNCORE_VERIFIER_CONNECT_TIMEOUT=10s

# SMTP operation deadline (Go duration, must be > 0).
SYNCORE_VERIFIER_OPERATION_TIMEOUT=10s

# Refresh the disposable-domain list on a daily schedule (true/false).
SYNCORE_VERIFIER_DISPOSABLE_AUTOUPDATE=false

# Suggest a likely-correct domain for probable typos (true/false).
SYNCORE_VERIFIER_DOMAIN_SUGGEST=true

# Maximum accepted POST body size in bytes (positive integer).
SYNCORE_VERIFIER_MAX_BODY_BYTES=4096

# Bearer token required on the verification endpoints (/health stays open). When
# unset, auth is disabled — allowed ONLY on a loopback bind. Startup fails fast
# if BIND_ADDR is non-loopback and this is unset.
# SYNCORE_VERIFIER_AUTH_TOKEN=replace-with-a-long-random-secret

# Result cache. CACHE_TTL is the lifetime for terminal (valid/invalid) results;
# 0 (the default) disables the cache. CACHE_TTL_UNKNOWN is the (shorter) lifetime
# for retryable unknown results; 0 -> min(CACHE_TTL, 1m).
# SYNCORE_VERIFIER_CACHE_TTL=0
# SYNCORE_VERIFIER_CACHE_TTL_UNKNOWN=0
# SYNCORE_VERIFIER_CACHE_MAX_ENTRIES=10000

# Batch endpoint (POST /v1/verifications:batch) bounds. The worst-case batch
# duration is ceil(BATCH_MAX_ITEMS / BATCH_CONCURRENCY) * (CONNECT + OPERATION)
# timeout; the CRM must chunk requests to BATCH_MAX_ITEMS. See deploy/README.md.
SYNCORE_VERIFIER_BATCH_MAX_ITEMS=100
SYNCORE_VERIFIER_BATCH_CONCURRENCY=10
SYNCORE_VERIFIER_BATCH_MAX_BODY_BYTES=65536

# Enable free SPF/DMARC/MX domain-health lookups, added to the response evidence
# (true/false). Off by default; adds DNS TXT lookups per verification.
# SYNCORE_VERIFIER_DOMAIN_HEALTH=false

# --- Storage backend (result cache + idempotency) ---
# memory (default) or postgres. DATABASE_URL is required when STORE=postgres.
# SYNCORE_VERIFIER_STORE=memory
# SYNCORE_VERIFIER_DATABASE_URL=postgres://user:pass@localhost:5432/verifier

# --- Async batch API (POST /batches) ---
# Worker-pool size, max emails per submission, and retry policy for retryable
# (unknown) results. RETRY_MAX_ATTEMPTS=0 disables retries.
# SYNCORE_VERIFIER_WORKERS=4
# SYNCORE_VERIFIER_ASYNC_BATCH_MAX_ITEMS=10000
# SYNCORE_VERIFIER_RETRY_MAX_ATTEMPTS=0
# SYNCORE_VERIFIER_RETRY_BACKOFF=0s
# HMAC-SHA256 signing key for async-batch completion webhooks (empty = unsigned).
# SYNCORE_VERIFIER_WEBHOOK_SIGNING_KEY=

# --- Rate limiting ---
# Requests per client (bearer token or IP) per minute; 0 disables.
# SYNCORE_VERIFIER_RATE_LIMIT_PER_MINUTE=0

# --- API keys (additional accepted credentials) ---
# Comma-separated "name:key" or bare "key"; each authenticates like the bearer
# token and is hashed at load. Satisfies the safe-bind requirement.
# SYNCORE_VERIFIER_API_KEYS=crm:replace-me,partner:replace-me-too

# --- Compliance: do-not-verify suppression list ---
# Comma-separated addresses; suppressed addresses skip all network checks and
# return suppressed=true.
# SYNCORE_VERIFIER_SUPPRESS_EMAILS=blocked@example.com

# --- Feedback loop (POST /v1/feedback) ---
# HMAC signing key that enables signed bounce/complaint/engagement ingestion.
# Empty disables the endpoint.
# SYNCORE_VERIFIER_FEEDBACK_SIGNING_KEY=
